            "title": "Edited Timestamp",
            "description": "Edit timestamp if edited"
          }
        },
        "type": "object",
        "required": [
          "id",
          "channel_id",
          "author_id",
          "author_name",
          "content",
          "timestamp"
        ],
        "title": "MessageDetail",
        "description": "Discord message details."
