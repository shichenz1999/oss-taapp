          "id": {
            "type": "string",
            "title": "Id",
            "description": "Channel ID"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Channel name"
          },
          "type": {
            "type": "string",
            "title": "Type",
            "description": "Channel type"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "type"
        ],
        "title": "ChannelInfo",
        "description": "Discord channel information."
      },
      "ChannelListResponse": {
        "properties": {
          "channels": {
            "items": {
              "$ref": "#/components/schemas/ChannelInfo"
