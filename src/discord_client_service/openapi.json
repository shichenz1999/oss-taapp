    "/auth/status/{guild_id}": {
      "get": {
        "summary": "Check authentication status",
        "description": "Check if guild is authenticated.",
        "operationId": "auth_status_auth_status__guild_id__get",
        "parameters": [
          {
            "name": "guild_id",
